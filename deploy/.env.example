# Required: 32+ char random string. openssl rand -hex 32
SESSION_SECRET=

# Required: 64 hex chars (32 bytes). openssl rand -hex 32
UPSTREAM_KEY_KMS=

# Required in production: lock /metrics behind this bearer token.
METRICS_TOKEN=

# Postgres credentials (override defaults if you want)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=claude_link

# Upstream Anthropic base URL. For testing: http://127.0.0.1:8000 etc.
ANTHROPIC_UPSTREAM_BASE_URL=https://api.anthropic.com

# Public HTTP port (what nginx listens on)
HTTP_PORT=80

LOG_LEVEL=info
