# Frontend env example. Copy to .env.local and edit.
# VITE_USE_MOCK=true (default) enables the in-browser Mock backend from src/lib/mock.js.
# Set to "false" to forward /api/* to the real backend via Vite proxy.
VITE_USE_MOCK=false

# Where Vite dev proxy forwards /api/* to. Only used in dev (npm run dev).
# In production, frontend and backend are same-origin behind nginx.
VITE_API_TARGET=http://localhost:8090
